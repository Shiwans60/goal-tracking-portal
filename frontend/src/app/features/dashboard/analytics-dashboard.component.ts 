    .q-value { font-size: 1.4rem; font-weight: 700; color: #1a237e; }
    .q-bar-wrap { height: 4px; background: #e0e0e0; border-radius: 2px; overflow: hidden; margin-top: 4px; }
    .q-bar-fill { height: 100%; border-radius: 2px; }
