import {
  Component, inject, OnInit, signal, OnDestroy,
  ElementRef, ViewChild, AfterViewInit
} from '@angular/core';
import { RouterLink } from '@angular/router';
import { DecimalPipe } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { HttpClient } from '@angular/common/http';
import { MatCardModule } from '@angular/material/card';
import { MatButtonModule } from '@angular/material/button';
import { MatIconModule } from '@angular/material/icon';
import { MatSelectModule } from '@angular/material/select';
import { MatFormFieldModule } from '@angular/material/form-field';
import { MatProgressBarModule } from '@angular/material/progress-bar';
import { MatChipsModule } from '@angular/material/chips';
import { MatTabsModule } from '@angular/material/tabs';
import { MatTooltipModule } from '@angular/material/tooltip';
import { MatDividerModule } from '@angular/material/divider';
import * as echarts from 'echarts';
import { ECharts, EChartsOption } from 'echarts';
import {
  DashboardService,
  EmployeeProgressSummary,
  TeamCompletionOverview,
  OrgCompletionMetrics,
  QoQTrend,
  QuarterStats,
} from '../../../core/services/dashboard.service';
import { AuthService } from '../../../core/services/auth.service';
import { environment } from '../../../../environments/environment';

interface Cycle { id: string; name: string; status: string; }

@Component({
  selector: 'app-analytics-dashboard',
  standalone: true,
  imports: [
    RouterLink, DecimalPipe, FormsModule,
    MatCardModule, MatButtonModule, MatIconModule,
    MatSelectModule, MatFormFieldModule, MatProgressBarModule,
    MatChipsModule, MatTabsModule, MatTooltipModule, MatDividerModule,
  ],
  template: `
    <div class="dashboard-page">

      <!-- ── Header ──────────────────────────────────────────────────────── -->
      <div class="dash-header">
        <div>
          <h2>Analytics Dashboard</h2>
          <p class="subtitle">Goal achievement insights and completion metrics</p>
        </div>
        <div class="header-controls">
          <mat-form-field appearance="outline" class="cycle-select">
            <mat-label>Cycle</mat-label>
            <mat-select [(ngModel)]="selectedCycleId" (ngModelChange)="onCycleChange()">
              @for (c of cycles(); track c.id) {
                <mat-option [value]="c.id">{{ c.name }}</mat-option>
              }
            </mat-select>
          </mat-form-field>
          <button mat-stroked-button (click)="loadAll()">
            <mat-icon>refresh</mat-icon> Refresh
          </button>
        </div>
      </div>

      @if (loading()) { <mat-progress-bar mode="indeterminate" /> }

      <!-- ── KPI Stat Cards ──────────────────────────────────────────────── -->
      <div class="kpi-grid">
        @if (mySummary()) {
          <div class="kpi-card kpi-score">
            <div class="kpi-icon">📈</div>
            <div class="kpi-value">
              {{ (mySummary()!.overallProgressScore * 100) | number:'1.0-1' }}%
            </div>
            <div class="kpi-label">My Overall Score</div>
          </div>
          <div class="kpi-card kpi-goals">
            <div class="kpi-icon">🎯</div>
            <div class="kpi-value">{{ mySummary()!.totalApprovedGoals }}</div>
            <div class="kpi-label">Approved Goals</div>
          </div>
          <div class="kpi-card kpi-q1">
            <div class="kpi-icon">📋</div>
            <div class="kpi-value">{{ mySummary()!.goalsWithCheckinQ1 }}</div>
            <div class="kpi-label">Q1 Check-ins</div>
          </div>
          <div class="kpi-card kpi-wt">
            <div class="kpi-icon">⚖️</div>
            <div class="kpi-value">{{ mySummary()!.totalWeightage | number:'1.0-0' }}%</div>
            <div class="kpi-label">Total Weightage</div>
          </div>
        }

        @if (isAdmin() && orgMetrics()) {
          <div class="kpi-card kpi-org">
            <div class="kpi-icon">🏢</div>
            <div class="kpi-value">{{ orgMetrics()!.totalEmployees }}</div>
            <div class="kpi-label">Total Employees</div>
          </div>
          <div class="kpi-card kpi-approved">
            <div class="kpi-icon">✅</div>
            <div class="kpi-value">{{ orgMetrics()!.approvedGoals }}</div>
            <div class="kpi-label">Approved Goals (Org)</div>
          </div>
        }
      </div>

      <!-- ── Tabs ─────────────────────────────────────────────────────────── -->
      <mat-tab-group class="tab-group" (selectedTabChange)="onTabChange($event)">

        <!-- ─ My Progress Tab ─ -->
        <mat-tab label="My Progress">
          <div class="tab-content">
            <div class="chart-grid">
              <!-- QoQ Trend Chart -->
              <mat-card class="chart-card wide">
                <mat-card-header>
                  <mat-card-title>
                    <mat-icon>trending_up</mat-icon>
                    Quarter-over-Quarter Progress Trend
                  </mat-card-title>
                  <mat-card-subtitle>Weighted progress score across Q1–Q4</mat-card-subtitle>
                </mat-card-header>
                <mat-card-content>
                  <div #qoqChart class="echart-container"></div>
                </mat-card-content>
              </mat-card>

              <!-- Quarter Completion Radial -->
              <mat-card class="chart-card">
                <mat-card-header>
                  <mat-card-title>
                    <mat-icon>donut_large</mat-icon>
                    Check-in Completion by Quarter
                  </mat-card-title>
                </mat-card-header>
                <mat-card-content>
                  <div #completionRadialChart class="echart-container"></div>
                </mat-card-content>
              </mat-card>

              <!-- Progress Status Breakdown -->
              <mat-card class="chart-card">
                <mat-card-header>
                  <mat-card-title>
                    <mat-icon>pie_chart</mat-icon>
                    Goal Status Breakdown
                  </mat-card-title>
                </mat-card-header>
                <mat-card-content>
                  <div #statusPieChart class="echart-container"></div>
                </mat-card-content>
              </mat-card>
            </div>

            <!-- Quarter Stats Table -->
            @if (mySummary()?.quarterStats?.length) {
              <mat-card class="stats-table-card">
                <mat-card-header>
                  <mat-card-title>Quarterly Breakdown</mat-card-title>
                </mat-card-header>
                <mat-card-content>
                  <table class="stats-table">
                    <thead>
                      <tr>
                        <th>Quarter</th>
                        <th>Goals</th>
                        <th>Checked In</th>
                        <th>Completion</th>
                        <th>Weighted Score</th>
                        <th>On Track</th>
                        <th>Completed</th>
                        <th>At Risk</th>
                      </tr>
                    </thead>
                    <tbody>
                      @for (q of mySummary()!.quarterStats; track q.quarter) {
                        <tr>
                          <td><strong>{{ q.quarter }}</strong></td>
                          <td>{{ q.totalGoals }}</td>
                          <td>{{ q.goalsCheckedIn }}</td>
                          <td>
                            <div class="pct-bar-wrap">
                              <div class="pct-bar"
                                   [style.width.%]="q.completionPct"
                                   [class.bar-good]="q.completionPct >= 80"
                                   [class.bar-medium]="q.completionPct >= 50 && q.completionPct < 80"
                                   [class.bar-poor]="q.completionPct < 50">
                              </div>
                              <span>{{ q.completionPct | number:'1.0-1' }}%</span>
                            </div>
                          </td>
                          <td>
                            <span [class.score-high]="q.weightedProgressScore >= 80"
                                  [class.score-medium]="q.weightedProgressScore >= 50 && q.weightedProgressScore < 80"
                                  [class.score-low]="q.weightedProgressScore < 50">
                              {{ q.weightedProgressScore | number:'1.0-1' }}%
                            </span>
                          </td>
                          <td class="count-on-track">{{ q.onTrackCount }}</td>
                          <td class="count-completed">{{ q.completedCount }}</td>
                          <td class="count-at-risk">{{ q.atRiskCount }}</td>
                        </tr>
                      }
                    </tbody>
                  </table>
                </mat-card-content>
              </mat-card>
            }
          </div>
        </mat-tab>

        <!-- ─ Team Overview Tab (Manager/Admin) ─ -->
        @if (isManagerOrAdmin()) {
          <mat-tab label="Team Overview">
            <div class="tab-content">
              <div class="chart-grid">
                <!-- Team Completion Bar Chart -->
                <mat-card class="chart-card wide">
                  <mat-card-header>
                    <mat-card-title>
                      <mat-icon>bar_chart</mat-icon>
                      Team Q1 Completion Rate
                    </mat-card-title>
                    <mat-card-subtitle>
                      {{ teamOverview()?.teamSize ?? 0 }} team members ·
                      Overall: {{ teamOverview()?.q1CompletionRate ?? 0 | number:'1.0-1' }}%
                    </mat-card-subtitle>
                  </mat-card-header>
                  <mat-card-content>
                    <div #teamBarChart class="echart-container"></div>
                  </mat-card-content>
                </mat-card>

                <!-- Team Score Heatmap-style cards -->
                <mat-card class="chart-card">
                  <mat-card-header>
                    <mat-card-title>
                      <mat-icon>people</mat-icon>
                      Member Progress Scores
                    </mat-card-title>
                  </mat-card-header>
                  <mat-card-content>
                    <div #teamScoreChart class="echart-container"></div>
                  </mat-card-content>
                </mat-card>
              </div>

              <!-- Team Member Table -->
              @if (teamOverview()?.memberRows?.length) {
                <mat-card class="stats-table-card">
                  <mat-card-header>
                    <mat-card-title>Team Member Details</mat-card-title>
                  </mat-card-header>
                  <mat-card-content>
                    <table class="stats-table">
                      <thead>
                        <tr>
                          <th>Employee</th>
                          <th>Dept</th>
                          <th>Approved Goals</th>
                          <th>Q1</th><th>Q2</th><th>Q3</th><th>Q4</th>
                          <th>Progress Score</th>
                        </tr>
                      </thead>
                      <tbody>
                        @for (m of teamOverview()!.memberRows; track m.employeeId) {
                          <tr>
                            <td><strong>{{ m.employeeName }}</strong></td>
                            <td>{{ m.department ?? '—' }}</td>
                            <td>{{ m.approvedGoals }}</td>
                            <td>
                              <span [class]="qBadgeClass(m.checkinQ1, m.approvedGoals)">
                                {{ m.checkinQ1 }}/{{ m.approvedGoals }}
                              </span>
                            </td>
                            <td>{{ m.checkinQ2 }}/{{ m.approvedGoals }}</td>
                            <td>{{ m.checkinQ3 }}/{{ m.approvedGoals }}</td>
                            <td>{{ m.checkinQ4 }}/{{ m.approvedGoals }}</td>
                            <td>
                              <div class="score-pill"
                                   [style.background]="scoreBg(m.weightedProgressScore)">
                                {{ (m.weightedProgressScore * 100) | number:'1.0-1' }}%
                              </div>
                            </td>
                          </tr>
                        }
                      </tbody>
                    </table>
                  </mat-card-content>
                </mat-card>
              }
            </div>
          </mat-tab>
        }

        <!-- ─ Org Analytics Tab (Admin) ─ -->
        @if (isAdmin()) {
          <mat-tab label="Org Analytics">
            <div class="tab-content">
              <div class="chart-grid">
                <!-- Org Completion by Quarter -->
                <mat-card class="chart-card wide">
                  <mat-card-header>
                    <mat-card-title>
                      <mat-icon>stacked_bar_chart</mat-icon>
                      Org-wide Check-in Completion (All Quarters)
                    </mat-card-title>
                  </mat-card-header>
                  <mat-card-content>
                    <div #orgCompletionChart class="echart-container"></div>
                  </mat-card-content>
                </mat-card>

                <!-- Department Breakdown -->
                <mat-card class="chart-card">
                  <mat-card-header>
                    <mat-card-title>
                      <mat-icon>pie_chart</mat-icon>
                      Employees by Department
                    </mat-card-title>
                  </mat-card-header>
                  <mat-card-content>
                    <div #deptPieChart class="echart-container"></div>
                  </mat-card-content>
                </mat-card>

                <!-- Goal Approval Stats -->
                <mat-card class="chart-card">
                  <mat-card-header>
                    <mat-card-title>
                      <mat-icon>fact_check</mat-icon>
                      Goal Approval Summary
                    </mat-card-title>
                  </mat-card-header>
                  <mat-card-content>
                    @if (orgMetrics()) {
                      <div class="approval-stats">
                        <div class="stat-row">
                          <span>Total Goals</span>
                          <strong>{{ orgMetrics()!.totalGoals }}</strong>
                        </div>
                        <div class="stat-row approved">
                          <span>Approved</span>
                          <strong>{{ orgMetrics()!.approvedGoals }}</strong>
                        </div>
                        <div class="stat-row">
                          <span>Approval Rate</span>
                          <strong>
                            {{ orgMetrics()!.totalGoals > 0
                                ? ((orgMetrics()!.approvedGoals / orgMetrics()!.totalGoals) * 100 | number:'1.0-1')
                                : 0 }}%
                          </strong>
                        </div>
                        <mat-divider class="my-12" />
                        <div class="q-completion-grid">
                          @for (qLabel of ['Q1','Q2','Q3','Q4']; track qLabel; let i = $index) {
                            <div class="q-cell">
                              <div class="q-label">{{ qLabel }}</div>
                              <div class="q-value">
                                {{ getQPct(i) | number:'1.0-1' }}%
                              </div>
                              <div class="q-bar-wrap">
                                <div class="q-bar-fill"
                                     [style.width.%]="getQPct(i)"
                                     [class.bar-good]="getQPct(i) >= 80"
                                     [class.bar-medium]="getQPct(i) >= 50"
                                     [class.bar-poor]="getQPct(i) < 50">
                                </div>
                              </div>
                            </div>
                          }
                        </div>
                      </div>
                    }
                  </mat-card-content>
                </mat-card>
              </div>
            </div>
          </mat-tab>
        }

      </mat-tab-group>
    </div>
  `,
  styles: [`
    .dashboard-page { padding: 24px; max-width: 1400px; margin: auto; }

    .dash-header {
      display: flex; justify-content: space-between; align-items: flex-start;
      margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
    }
    h2 { margin: 0; font-size: 1.5rem; }
    .subtitle { margin: 4px 0 0; color: #666; font-size: 14px; }
    .header-controls { display: flex; gap: 12px; align-items: center; }
    .cycle-select { width: 220px; }

    /* KPI Cards */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .kpi-card {
      padding: 20px 16px; border-radius: 12px;
      display: flex; flex-direction: column; align-items: center;
      text-align: center; border: 1px solid #e8e8e8;
      background: white; box-shadow: 0 2px 8px rgba(0,0,0,.06);
      transition: box-shadow .2s, transform .2s;
    }
    .kpi-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,.12); transform: translateY(-2px); }
    .kpi-icon { font-size: 2rem; margin-bottom: 8px; }
    .kpi-value { font-size: 2rem; font-weight: 700; line-height: 1.1; }
    .kpi-label { font-size: 12px; color: #666; margin-top: 4px; text-transform: uppercase; letter-spacing: .5px; }
    .kpi-score { background: linear-gradient(135deg, #e8f5e9, #f1f8e9); }
    .kpi-score .kpi-value { color: #2e7d32; }
    .kpi-goals { background: linear-gradient(135deg, #e3f2fd, #e8eaf6); }
    .kpi-goals .kpi-value { color: #1565c0; }
    .kpi-q1   { background: linear-gradient(135deg, #fff8e1, #fff3e0); }
    .kpi-q1 .kpi-value { color: #e65100; }
