      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 20px;
      margin-bottom: 20px;
    }
    .chart-card.wide { grid-column: span 2; }
    @media (max-width: 900px) { .chart-card.wide { grid-column: span 1; } }

    .echart-container { width: 100%; height: 300px; }

    /* Stats table */
    .stats-table-card { margin-top: 8px; }
    .stats-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .stats-table th {
      background: #1a237e; color: white; padding: 10px 12px;
      text-align: left; font-weight: 600; font-size: 12px;
      text-transform: uppercase; letter-spacing: .5px;
    }
    .stats-table td { padding: 10px 12px; border-bottom: 1px solid #f0f0f0; }
    .stats-table tr:hover td { background: #f9f9f9; }

    .pct-bar-wrap { display: flex; align-items: center; gap: 8px; min-width: 120px; }
    .pct-bar { height: 6px; border-radius: 3px; transition: width .3s; flex: 0 0 auto; }
