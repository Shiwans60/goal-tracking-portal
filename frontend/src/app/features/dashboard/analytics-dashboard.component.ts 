    .count-on-track  { color: #2e7d32; font-weight: 600; }
    .count-completed { color: #1565c0; font-weight: 600; }
    .count-at-risk   { color: #c62828; font-weight: 600; }

    /* Team badges */
    .score-pill {
      display: inline-block; padding: 4px 10px;
      border-radius: 12px; font-weight: 600; font-size: 13px;
      color: white;
    }
    .badge-good   { background: #4caf50; color: white; padding: 2px 8px; border-radius: 8px; font-size: 12px; }
    .badge-medium { background: #ff9800; color: white; padding: 2px 8px; border-radius: 8px; font-size: 12px; }
