})
export class AnalyticsDashboardComponent implements OnInit, AfterViewInit, OnDestroy {
  private dashService = inject(DashboardService);
  private auth        = inject(AuthService);
  private http        = inject(HttpClient);

  @ViewChild('qoqChart')             private qoqChartEl!:          ElementRef;
  @ViewChild('completionRadialChart') private radialChartEl!:       ElementRef;
  @ViewChild('statusPieChart')        private statusPieEl!:         ElementRef;
  @ViewChild('teamBarChart')          private teamBarEl!:           ElementRef;
  @ViewChild('teamScoreChart')        private teamScoreEl!:         ElementRef;
  @ViewChild('orgCompletionChart')    private orgCompletionEl!:     ElementRef;
  @ViewChild('deptPieChart')          private deptPieEl!:           ElementRef;

  private charts: ECharts[] = [];

  mySummary   = signal<EmployeeProgressSummary | null>(null);
  myTrend     = signal<QoQTrend | null>(null);
  teamOverview = signal<TeamCompletionOverview | null>(null);
  orgMetrics   = signal<OrgCompletionMetrics | null>(null);
  cycles       = signal<Cycle[]>([]);
  loading      = signal(true);
  selectedCycleId: string | undefined;

  isAdmin          = () => this.auth.hasRole('ROLE_ADMIN');
  isManagerOrAdmin = () => this.auth.hasRole('ROLE_ADMIN', 'ROLE_MANAGER');

  ngOnInit() {
    this.http.get<Cycle[]>(`${environment.apiBaseUrl}/api/admin/cycles/all`).subscribe({
      next: cs => {
        this.cycles.set(cs);
        const active = cs.find(c => c.status === 'ACTIVE');
        if (active) this.selectedCycleId = active.id;
        this.loadAll();
      },
      error: () => this.loadAll(),
    });
  }

  ngAfterViewInit() {
    // Charts are rendered after data loads
  }

  ngOnDestroy() {
    this.charts.forEach(c => c.dispose());
  }

  onCycleChange() { this.loadAll(); }

  onTabChange(event: any) {
    // Resize charts when switching tabs (ECharts needs explicit resize)
    setTimeout(() => this.charts.forEach(c => c.resize()), 100);
  }

  loadAll() {
    this.loading.set(true);

    this.dashService.getMyProgressSummary(this.selectedCycleId).subscribe({
      next: s => {
        this.mySummary.set(s);
        this.loading.set(false);
        setTimeout(() => this.renderMyCharts(), 200);
      },
      error: () => this.loading.set(false),
    });

    this.dashService.getMyQoQTrend(this.selectedCycleId).subscribe({
      next: t => {
        this.myTrend.set(t);
        setTimeout(() => this.renderQoQChart(), 200);
      },
      error: () => {},
    });

    if (this.isManagerOrAdmin()) {
      this.dashService.getTeamCompletionOverview(this.selectedCycleId).subscribe({
        next: t => {
          this.teamOverview.set(t);
          setTimeout(() => this.renderTeamCharts(), 200);
        },
        error: () => {},
      });
    }

    if (this.isAdmin()) {
      this.dashService.getOrgCompletionMetrics(this.selectedCycleId).subscribe({
        next: m => {
          this.orgMetrics.set(m);
          setTimeout(() => this.renderOrgCharts(), 200);
        },
        error: () => {},
      });
    }
  }

  // ── Chart Renderers ───────────────────────────────────────────────────────

  private renderQoQChart() {
    if (!this.qoqChartEl || !this.myTrend()) return;
    const chart = this.initChart(this.qoqChartEl);
    const dp = this.myTrend()!.dataPoints;

    const option: EChartsOption = {
      tooltip: { trigger: 'axis', formatter: (params: any) => {
        const p = params[0];
        return `<strong>${p.name}</strong><br/>Score: ${p.value}%`;
      }},
      xAxis: { type: 'category', data: dp.map(d => d.quarter), axisLine: { lineStyle: { color: '#e0e0e0' }} },
      yAxis: { type: 'value', max: 100, axisLabel: { formatter: '{value}%' }, splitLine: { lineStyle: { color: '#f5f5f5' }} },
      series: [{
        data: dp.map(d => +d.weightedScore.toFixed(1)),
        type: 'line',
        smooth: true,
        symbol: 'circle',
        symbolSize: 8,
        lineStyle: { color: '#1a237e', width: 3 },
        itemStyle: { color: '#1a237e' },
        areaStyle: { color: { type: 'linear', x: 0, y: 0, x2: 0, y2: 1, colorStops: [
          { offset: 0, color: 'rgba(26,35,126,0.25)' },
          { offset: 1, color: 'rgba(26,35,126,0.02)' }
        ]}},
        label: { show: true, position: 'top', formatter: '{c}%', color: '#333' }
      }],
      grid: { left: 40, right: 20, top: 30, bottom: 30 }
    };
    chart.setOption(option);
  }

  private renderMyCharts() {
    if (!this.mySummary()) return;
    this.renderCompletionRadial();
    this.renderStatusPie();
  }

  private renderCompletionRadial() {
    if (!this.radialChartEl || !this.mySummary()) return;
    const chart = this.initChart(this.radialChartEl);
    const s = this.mySummary()!;
    const total = s.totalApprovedGoals || 1;

    const option: EChartsOption = {
      tooltip: { trigger: 'item' },
      legend: { orient: 'vertical', right: 10, top: 'center' },
      series: [{
        type: 'pie',
        radius: ['40%', '70%'],
        avoidLabelOverlap: false,
        padAngle: 3,
        itemStyle: { borderRadius: 6 },
        label: { show: true, formatter: '{b}\n{c}' },
        data: [
          { value: s.goalsWithCheckinQ1, name: 'Q1', itemStyle: { color: '#1a237e' } },
          { value: s.goalsWithCheckinQ2, name: 'Q2', itemStyle: { color: '#1565c0' } },
          { value: s.goalsWithCheckinQ3, name: 'Q3', itemStyle: { color: '#1976d2' } },
          { value: s.goalsWithCheckinQ4, name: 'Q4', itemStyle: { color: '#42a5f5' } },
        ]
      }]
    };
    chart.setOption(option);
  }

  private renderStatusPie() {
    if (!this.statusPieEl || !this.mySummary()) return;
    const chart = this.initChart(this.statusPieEl);
    const qs = this.mySummary()!.quarterStats;
    if (!qs?.length) return;

    // Aggregate status counts across all quarters
    const onTrack   = qs.reduce((s, q) => s + q.onTrackCount, 0);
    const completed = qs.reduce((s, q) => s + q.completedCount, 0);
    const atRisk    = qs.reduce((s, q) => s + q.atRiskCount, 0);
    const pending   = qs.reduce((s, q) => s + q.goalsPending, 0);

    const option: EChartsOption = {
      tooltip: { trigger: 'item', formatter: '{b}: {c} ({d}%)' },
      legend: { orient: 'vertical', right: 10, top: 'center', textStyle: { fontSize: 12 } },
      series: [{
        type: 'pie',
        radius: ['35%', '65%'],
        padAngle: 3,
        itemStyle: { borderRadius: 6 },
        label: { show: false },
        emphasis: { label: { show: true, fontSize: 14, fontWeight: 'bold' } },
        data: [
          { value: completed, name: 'Completed',   itemStyle: { color: '#1565c0' } },
          { value: onTrack,   name: 'On Track',    itemStyle: { color: '#4caf50' } },
          { value: atRisk,    name: 'At Risk',     itemStyle: { color: '#f44336' } },
          { value: pending,   name: 'Not Started', itemStyle: { color: '#e0e0e0' } },
        ]
      }]
    };
    chart.setOption(option);
  }

  private renderTeamCharts() {
    if (!this.teamOverview()) return;
    this.renderTeamBar();
    this.renderTeamScoreChart();
  }

  private renderTeamBar() {
    if (!this.teamBarEl || !this.teamOverview()) return;
    const chart = this.initChart(this.teamBarEl);
    const members = this.teamOverview()!.memberRows;

    const option: EChartsOption = {
      tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
      legend: { data: ['Q1', 'Q2', 'Q3', 'Q4'] },
      xAxis: { type: 'category', data: members.map(m => m.employeeName.split(' ')[0]),
               axisLabel: { rotate: 30, fontSize: 11 } },
      yAxis: { type: 'value', max: 100, axisLabel: { formatter: '{value}%' },
               splitLine: { lineStyle: { color: '#f5f5f5' }} },
      series: [
        { name: 'Q1', type: 'bar', stack: 'total', barMaxWidth: 40, itemStyle: { color: '#1a237e' },
          data: members.map(m => m.approvedGoals > 0 ? +(m.checkinQ1/m.approvedGoals*100).toFixed(0) : 0) },
        { name: 'Q2', type: 'bar', stack: 'total', barMaxWidth: 40, itemStyle: { color: '#1565c0' },
          data: members.map(m => m.approvedGoals > 0 ? +(m.checkinQ2/m.approvedGoals*100).toFixed(0) : 0) },
        { name: 'Q3', type: 'bar', stack: 'total', barMaxWidth: 40, itemStyle: { color: '#1976d2' },
          data: members.map(m => m.approvedGoals > 0 ? +(m.checkinQ3/m.approvedGoals*100).toFixed(0) : 0) },
        { name: 'Q4', type: 'bar', stack: 'total', barMaxWidth: 40, itemStyle: { color: '#42a5f5' },
          data: members.map(m => m.approvedGoals > 0 ? +(m.checkinQ4/m.approvedGoals*100).toFixed(0) : 0) },
      ],
      grid: { left: 40, right: 20, top: 50, bottom: 60 }
    };
    chart.setOption(option);
  }

  private renderTeamScoreChart() {
    if (!this.teamScoreEl || !this.teamOverview()) return;
    const chart = this.initChart(this.teamScoreEl);
    const members = [...this.teamOverview()!.memberRows]
        .sort((a, b) => +b.weightedProgressScore - +a.weightedProgressScore);

    const option: EChartsOption = {
      tooltip: { trigger: 'axis', formatter: (p: any) => `${p[0].name}: ${(p[0].value * 100).toFixed(1)}%` },
      xAxis: { type: 'category', data: members.map(m => m.employeeName.split(' ')[0]),
               axisLabel: { rotate: 30, fontSize: 11 } },
      yAxis: { type: 'value', max: 1, axisLabel: { formatter: (v: number) => `${(v * 100).toFixed(0)}%` },
               splitLine: { lineStyle: { color: '#f5f5f5' }} },
      series: [{
        type: 'bar',
        barMaxWidth: 40,
        data: members.map(m => ({
          value: +m.weightedProgressScore,
          itemStyle: {
            color: +m.weightedProgressScore >= 0.8 ? '#4caf50'
                : +m.weightedProgressScore >= 0.5 ? '#ff9800' : '#f44336'
          }
        })),
        label: { show: true, position: 'top',
                 formatter: (p: any) => `${(p.value * 100).toFixed(0)}%` }
      }],
      grid: { left: 50, right: 20, top: 30, bottom: 60 }
    };
    chart.setOption(option);
  }

  private renderOrgCharts() {
    if (!this.orgMetrics()) return;
    this.renderOrgCompletion();
    this.renderDeptPie();
  }

  private renderOrgCompletion() {
    if (!this.orgCompletionEl || !this.orgMetrics()) return;
    const chart = this.initChart(this.orgCompletionEl);
    const m = this.orgMetrics()!;

    const option: EChartsOption = {
      tooltip: { trigger: 'axis', formatter: (p: any) =>
        p.map((s: any) => `${s.seriesName}: ${s.value}%`).join('<br/>') },
      legend: { data: ['Completion %'], top: 10 },
      xAxis: { type: 'category', data: ['Q1', 'Q2', 'Q3', 'Q4'] },
      yAxis: { type: 'value', max: 100, axisLabel: { formatter: '{value}%' },
               splitLine: { lineStyle: { color: '#f5f5f5' }} },
      series: [
        {
          name: 'Completion %', type: 'bar', barWidth: 60,
          data: [
            { value: +m.q1CompletionPct, itemStyle: { color: this.pctColor(+m.q1CompletionPct) } },
            { value: +m.q2CompletionPct, itemStyle: { color: this.pctColor(+m.q2CompletionPct) } },
            { value: +m.q3CompletionPct, itemStyle: { color: this.pctColor(+m.q3CompletionPct) } },
            { value: +m.q4CompletionPct, itemStyle: { color: this.pctColor(+m.q4CompletionPct) } },
          ],
          label: { show: true, position: 'top', formatter: '{c}%' }
        }
      ],
      grid: { left: 50, right: 20, top: 50, bottom: 30 }
    };
    chart.setOption(option);
  }

  private renderDeptPie() {
    if (!this.deptPieEl || !this.orgMetrics()) return;
    const chart = this.initChart(this.deptPieEl);
    const depts = this.orgMetrics()!.employeesByDepartment ?? [];

    const colors = ['#1a237e','#1565c0','#1976d2','#1e88e5','#42a5f5','#90caf9','#bbdefb'];

    const option: EChartsOption = {
      tooltip: { trigger: 'item', formatter: '{b}: {c} ({d}%)' },
      legend: { orient: 'vertical', right: 10, top: 'center', textStyle: { fontSize: 11 } },
      series: [{
        type: 'pie',
        radius: ['40%', '70%'],
        padAngle: 3,
        itemStyle: { borderRadius: 6 },
        label: { show: false },
        emphasis: { label: { show: true, fontWeight: 'bold' } },
        data: depts.map((d, i) => ({
          value: d.count,
          name: d.department ?? 'Unknown',
          itemStyle: { color: colors[i % colors.length] }
        }))
      }]
    };
    chart.setOption(option);
  }

  // ── Helpers ───────────────────────────────────────────────────────────────

  private initChart(ref: ElementRef): ECharts {
    const existing = echarts.getInstanceByDom(ref.nativeElement);
    if (existing) { existing.dispose(); }
    const chart = echarts.init(ref.nativeElement, null, { renderer: 'canvas' });
    this.charts.push(chart);
    window.addEventListener('resize', () => chart.resize());
    return chart;
  }

  pctColor(pct: number): string {
    if (pct >= 80) return '#4caf50';
    if (pct >= 50) return '#ff9800';
    return '#f44336';
  }

  scoreBg(score: number): string {
    const s = +score;
    if (s >= 0.8) return '#4caf50';
    if (s >= 0.5) return '#ff9800';
    return '#f44336';
  }

  qBadgeClass(checked: number, total: number): string {
    if (total === 0) return '';
    const pct = (checked / total) * 100;
    if (pct >= 80) return 'badge-good';
    if (pct >= 50) return 'badge-medium';
    return 'badge-poor';
  }

  getQPct(quarterIndex: number): number {
    const m = this.orgMetrics();
    if (!m) return 0;
    const vals = [+m.q1CompletionPct, +m.q2CompletionPct, +m.q3CompletionPct, +m.q4CompletionPct];
    return vals[quarterIndex] ?? 0;
  }
}